<script>
const ctx = document.getElementById('chart')
            .getContext('2d');
const chart = new Chart(ctx, {
  type: 'line',
  data: {
    labels: [],
    datasets: [
      {
        label: 'Tomato',
        data: [],
        borderColor: '#c62828',
        backgroundColor: 'rgba(198,40,40,0.06)',
        tension: 0.4, fill: true, pointRadius: 3,
        pointBackgroundColor: '#c62828'
      },
      {
        label: 'Mint',
        data: [],
        borderColor: '#2e7d32',
        backgroundColor: 'rgba(46,125,50,0.06)',
        tension: 0.4, fill: true, pointRadius: 3,
        pointBackgroundColor: '#2e7d32'
      }
    ]
  },
  options: {
    responsive: true,
    plugins: { legend: { display: false } },
    scales: {
      y: {
        min: 0, max: 100,
        grid: { color: 'rgba(0,0,0,0.04)' },
        title: {
          display: true, text: 'Moisture %',
          color: '#888', font: { size: 11 }
        }
      },
      x: { grid: { display: false } }
    }
  }
});

const icons = {
  'Regular Tomato':'🍅','Cherry Tomato':'🍒',
  'Roma Tomato':'🍅','Mint':'🌿',
  'Loamy':'🟢','Red Soil':'🔴','Clay':'🟤',
  'Pot':'🪴','Garden Bed':'🌿','Open Ground':'🌍',
  'Small':'🌱','Medium':'🌿','Large':'🌳'
};

let readingCount = 0;

function updateSettings() {
  const plant    = document.getElementById('plant').value;
  const soil     = document.getElementById('soil').value;
  const location = document.getElementById('location').value;
  const size     = document.getElementById('size').value;

  document.getElementById('chips').innerHTML =
    `<span class="chip">${icons[plant]||'🌿'} ${plant}</span>
     <span class="chip">${icons[soil]||'🟤'} ${soil}</span>
     <span class="chip">${icons[location]||'📍'} ${location}</span>
     <span class="chip">${icons[size]||'📏'} ${size}</span>`;

  document.getElementById('active-badge')
    .textContent = plant + ' Active';

  fetch('/update_settings', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({plant,soil,location,size})
  });
}

function update() {
  fetch('/api').then(r => r.json()).then(d => {
    readingCount++;

    // Soil
    document.getElementById('tomato-soil')
      .textContent = d.tomato_moisture + '%';
    document.getElementById('mint-soil')
      .textContent = d.mint_moisture + '%';
    document.getElementById('tomato-bar')
      .style.width = d.tomato_moisture + '%';
    document.getElementById('mint-bar')
      .style.width = d.mint_moisture + '%';

    let soil = d.selected_plant !== 'Mint' ?
               d.tomato_moisture : d.mint_moisture;
    let dry  = d.selected_plant === 'Mint' ? 50 : 40;
    let wet  = d.selected_plant === 'Mint' ? 75 : 70;
    let sm   = document.getElementById('soil-msg');
    if (soil < dry) {
      sm.className = 'soil-msg msg-dry';
      sm.textContent = '⚠️ Too Dry — Plant Needs Water!';
    } else if (soil > wet) {
      sm.className = 'soil-msg msg-wet';
      sm.textContent = '💧 Too Wet — Let it Dry!';
    } else {
      sm.className = 'soil-msg msg-ok';
      sm.textContent = '✅ Soil Moisture is Perfect!';
    }

    // Environment
    let te = document.getElementById('temp');
    te.textContent = d.temperature + '°C';
    te.style.color = d.temperature > 35 ?
      '#c62828' : '#e53935';
    document.getElementById('hum')
      .textContent = d.humidity + '%';

    // Water
    document.getElementById('water')
      .textContent = d.water_needed;
    document.getElementById('pump-time')
      .textContent = d.pump_seconds + ' sec';
    document.getElementById('pump-min')
      .textContent = d.pump_minutes || '';

    // Action
    let ab = document.getElementById('action');
    ab.textContent = d.action;
    ab.style.background = d.action_color;

    // Pump status
    let dot = document.getElementById('pump-dot');
    let ps  = document.getElementById('pump-status');
    if (d.pump_status &&
        d.pump_status.includes('RUNNING')) {
      dot.className = 'pump-dot running';
      ps.textContent = '💧 ' + d.pump_status;
    } else {
      dot.className = 'pump-dot';
      ps.textContent = '⚡ Pump: ' +
        (d.pump_status || 'STANDBY');
    }

    // Health
    document.getElementById('health')
      .textContent = d.health_score;
    document.getElementById('health-bar')
      .style.width = d.health_score + '%';
    document.getElementById('health-status')
      .textContent = d.health_status;

    // Stats
    document.getElementById('times-watered')
      .textContent = d.times_watered || 0;
    document.getElementById('total-water')
      .textContent = Math.round(d.total_water || 0);
    document.getElementById('reading-count')
      .textContent = readingCount;

    // Watering log
    if (d.watering_log && d.watering_log.length > 0) {
      let html = '';
      [...d.watering_log].reverse().forEach(log => {
        html += `
          <div class="log-item">
            <span class="log-time">${log.time}</span>
            <span class="log-plant">${log.plant}</span>
            <span class="log-water">
              ${log.water}ml (${log.sec}s)</span>
          </div>`;
      });
      document.getElementById('watering-log')
        .innerHTML = html;
    }

    // Updated time
    document.getElementById('updated')
      .textContent = '🕐 Last updated: ' + d.last_updated;

    // Chart
    if (d.history && d.history.length > 0) {
      chart.data.labels = d.history.map(h => h.time);
      chart.data.datasets[0].data =
        d.history.map(h => h.tomato);
      chart.data.datasets[1].data =
        d.history.map(h => h.mint);
      chart.update('none');
    }
  });
}

update();
setInterval(update, 5000);
</script>
</html>
''')

