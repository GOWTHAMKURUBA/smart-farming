# ==========================================
# ML PREDICTION
# ==========================================
def predict_water(plant, soil, temp, hum,
                  soil_type, location, size):
    try:
        inp = pd.DataFrame(
            [[soil, temp, hum,
              PLANT_ENC[plant],
              SOIL_ENC[soil_type],
              LOCATION_ENC[location],
              SIZE_ENC[size]]],
            columns=['soil_moisture','temperature',
                     'humidity','plant_encoded',
                     'soil_encoded','location_encoded',
                     'size_encoded'])
        return max(0, round(model.predict(inp)[0], 1))
    except Exception as e:
        print(f"Prediction error: {e}")
        return 0

# ==========================================
# HEALTH SCORE
# ==========================================
def calculate_health(soil, temp, hum, plant):
    score = 100
    dry = 50 if 'Mint' in plant else 40
    wet = 75 if 'Mint' in plant else 70

    if soil < dry - 20:  score -= 40
    elif soil < dry:     score -= 20
    elif soil > wet:     score -= 15
    if temp > 38:        score -= 30
    elif temp > 35:      score -= 15
    if hum > 80:         score -= 20
    elif hum < 30:       score -= 10
    score = max(0, score)

    if score >= 80:   status = "🌟 Excellent!"
    elif score >= 60: status = "✅ Good"
    elif score >= 40: status = "⚠️ Needs Attention"
    else:             status = "🚨 Critical!"
    return score, status

# ==========================================
# SEND COMMAND TO ARDUINO
# ==========================================
def send_to_arduino(cmd):
    try:
        if arduino_conn and arduino_conn.is_open:
            arduino_conn.write(f"{cmd}\n".encode())
            print(f"→ Arduino: {cmd}")
    except Exception as e:
        print(f"Send error: {e}")

# ==========================================
# READ ARDUINO
# ==========================================
def read_arduino():
    global arduino_conn
    try:
        arduino_conn = serial.Serial(
            'COM12', 9600, timeout=2)
        time.sleep(2)
        print("✅ Arduino connected on COM17!")

        while True:
            try:
                line = arduino_conn.readline()\
                    .decode('utf-8').strip()

                if not line:
                    continue

                # ---- Parse CSV Data ----
                if line.startswith('CSV,'):
                    parts = line.split(',')
                    if len(parts) >= 7:
                        # Plant number from Arduino
                        plant_num = parts[2]
                        tomato = float(parts[3])
                        mint   = float(parts[4])
                        temp   = float(parts[5])
                        hum    = float(parts[6])

                        # Use selected plant from dashboard
                        plant = sensor_data["selected_plant"]
                        soil  = tomato if plant != 'Mint' \
                                else mint

                        # ML Prediction
                        water = predict_water(
                            plant, soil, temp, hum,
                            sensor_data["soil_type"],
                            sensor_data["location"],
                            sensor_data["plant_size"])

                        # Pump duration — NO LIMIT!
                        dur_ms  = water * MS_PER_ML
                        dur_sec = round(dur_ms / 1000, 1)
                        dur_min = ""
                        if dur_sec > 60:
                            dur_min = f"({round(dur_sec/60,1)} min)"

                        # Health score
                        score, status = calculate_health(
                            soil, temp, hum, plant)

                        # Action message
                        if water > 500:
                            action = "🚨 Water Immediately!"
                            color  = "#c62828"
                        elif water > 200:
                            action = "⚠️ Water Soon"
                            color  = "#e65100"
                        elif water > 100:
                            action = "👀 Monitor Closely"
                            color  = "#f57f17"
                        else:
                            action = "✅ No Watering Needed"
                            color  = "#2e7d32"

                        now = datetime.now()\
                            .strftime("%H:%M:%S")

                        sensor_data.update({
                            "tomato_moisture" : tomato,
                            "mint_moisture"   : mint,
                            "temperature"     : temp,
                            "humidity"        : hum,
                            "water_needed"    : water,
                            "pump_seconds"    : dur_sec,
                            "pump_minutes"    : dur_min,
                            "health_score"    : score,
                            "health_status"   : status,
                            "action"          : action,
                            "action_color"    : color,
                            "last_updated"    : now
                        })

                        sensor_data["history"].append({
                            "time"  : now,
                            "tomato": tomato,
                            "mint"  : mint
                        })
                        if len(sensor_data["history"]) > 20:
                            sensor_data["history"].pop(0)

                        print(f"[{now}] {plant} | "
                              f"T:{tomato}% M:{mint}% | "
                              f"{temp}C {hum}% | "
                              f"💧{water}ml ({dur_sec}s)")

                # ---- Detect Pump Events ----
                elif "PUMP STARTING" in line:
                    sensor_data["pump_status"] = "RUNNING 💧"
                    sensor_data["times_watered"] += 1
                    sensor_data["total_water"] += \
                        sensor_data["water_needed"]
                    sensor_data["watering_log"].append({
                        "time" : datetime.now()
                                 .strftime("%H:%M:%S"),
                        "plant": sensor_data["selected_plant"],
                        "water": sensor_data["water_needed"],
                        "sec"  : sensor_data["pump_seconds"]
                    })
                    if len(sensor_data["watering_log"]) > 10:
                        sensor_data["watering_log"].pop(0)
                    print("💧 Pump started!")

                elif "PUMP COMPLETE" in line:
                    sensor_data["pump_status"] = "STANDBY ✅"
                    print("✅ Pump complete!")

            except UnicodeDecodeError:
                pass
            except Exception as e:
                pass

    except Exception as e:
        print(f"❌ Arduino error: {e}")
        print("🔄 Running in DEMO mode...")
        _demo_mode()

