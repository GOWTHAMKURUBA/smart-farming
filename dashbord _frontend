        tomato = round(random.uniform(10, 90), 1)
        mint   = round(random.uniform(10, 90), 1)
        temp   = round(random.uniform(28, 35), 1)
        hum    = round(random.uniform(45, 65), 1)
        plant  = sensor_data["selected_plant"]
        soil   = tomato if plant != 'Mint' else mint

        water = predict_water(
            plant, soil, temp, hum,
            sensor_data["soil_type"],
            sensor_data["location"],
            sensor_data["plant_size"])

        dur_sec = round(water * MS_PER_ML / 1000, 1)
        dur_min = f"({round(dur_sec/60,1)} min)" \
            if dur_sec > 60 else ""

        score, status = calculate_health(
            soil, temp, hum, plant)

        if water > 500:
            action,color = "🚨 Water Immediately!","#c62828"
        elif water > 200:
            action,color = "⚠️ Water Soon","#e65100"
        elif water > 100:
            action,color = "👀 Monitor Closely","#f57f17"
        else:
            action,color = "✅ No Watering Needed","#2e7d32"

        now = datetime.now().strftime("%H:%M:%S")

        sensor_data.update({
            "tomato_moisture" : tomato,
            "mint_moisture"   : mint,
            "temperature"     : temp,
            "humidity"        : hum,
            "water_needed"    : water,
            "pump_seconds"    : dur_sec,
            "pump_minutes"    : dur_min,
            "health_score"    : score,
            "health_status"   : status,
            "action"          : action,
            "action_color"    : color,
            "last_updated"    : now
        })
        sensor_data["history"].append({
            "time": now, "tomato": tomato, "mint": mint
        })
        if len(sensor_data["history"]) > 20:
            sensor_data["history"].pop(0)
        time.sleep(5)

