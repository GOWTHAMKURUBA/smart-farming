@app.route('/update_settings', methods=['POST'])
def update_settings():
    data = request.json

    if 'plant' in data:
        sensor_data["selected_plant"] = data['plant']
        send_to_arduino(
            PLANT_CMD.get(data['plant'], 'PLANT:TOMATO'))

    if 'soil' in data:
        sensor_data["soil_type"] = data['soil']
        send_to_arduino(
            SOIL_CMD.get(data['soil'], 'SOIL:LOAMY'))

    if 'location' in data:
        sensor_data["location"] = data['location']
        send_to_arduino(
            LOCATION_CMD.get(data['location'], 'LOC:POT'))

    if 'size' in data:
        sensor_data["plant_size"] = data['size']
        send_to_arduino(
            SIZE_CMD.get(data['size'], 'SIZE:SMALL'))

    print(f"✅ Settings → "
          f"{sensor_data['selected_plant']} | "
          f"{sensor_data['soil_type']} | "
          f"{sensor_data['location']} | "
          f"{sensor_data['plant_size']}")

    return jsonify({"status": "ok"})

